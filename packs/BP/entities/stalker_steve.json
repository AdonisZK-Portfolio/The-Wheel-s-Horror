{
    "format_version": "1.21.100",
    "minecraft:entity": {
        "description": {
            "identifier": "stalker:steve",
            "spawn_category": "monster",
            "is_spawnable": false,
            "is_summonable": true
        },
        "component_groups": {
            "stalker:wandering": {
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 2,
                    "must_see": true,
                    "within_radius": 4,
                    "reselect_targets": true,
                    "entity_types": [
                        {
                            "filters": {
                                "test": "is_family",
                                "subject": "other",
                                "operator": "==",
                                "value": "player"
                            },
                            "max_dist": 4
                        }
                    ]
                },
                "minecraft:behavior.melee_attack": {
                    "priority": 3,
                    "track_target": true,
                    "speed_multiplier": 1.0,
                    "reach_multiplier": 1.2,
                    "cooldown_time": 1.0
                },
                "minecraft:behavior.random_stroll": {
                    "priority": 8,
                    "speed_multiplier": 0.6,
                    "xz_dist": 8,
                    "y_dist": 3,
                    "interval": 60
                },
                "minecraft:behavior.random_look_around": {
                    "priority": 9
                }
            }
        },
        "components": {
            "minecraft:nameable": {
                "always_show": true
            },
            "minecraft:type_family": {
                "family": ["stalker_steve", "monster", "mob"]
            },
            "minecraft:health": {
                "value": 20,
                "max": 20
            },
            "minecraft:attack": {
                "damage": 4
            },
            "minecraft:movement": {
                "value": 0.25
            },
            "minecraft:follow_range": {
                "value": 4,
                "max": 4
            },
            "minecraft:equippable": {
                "slots": [
                    {
                        "slot": 0
                    }
                ]
            },
            "minecraft:movement.basic": {},
            "minecraft:navigation.walk": {
                "can_path_over_water": false,
                "avoid_water": true,
                "can_open_doors": false,
                "can_pass_doors": true
            },
            "minecraft:physics": {},
            "minecraft:jump.static": {},
            "minecraft:can_climb": {},
            "minecraft:behavior.look_at_player": {
                "priority": 7,
                "look_distance": 8,
                "probability": 0.02
            }
        },
        "events": {
            "minecraft:entity_spawned": {
                "add": {
                    "component_groups": ["stalker:wandering"]
                }
            },
            "stalker:freeze": {
                "remove": {
                    "component_groups": ["stalker:wandering"]
                }
            },
            "stalker:unfreeze": {
                "add": {
                    "component_groups": ["stalker:wandering"]
                }
            }
